# Budget Buddy API Server 환경 설정 예시
# 이 파일을 복사해서 .env 로 사용하세요: cp .env.example .env

NODE_ENV=development
PORT=3000

# Gemini AI API Key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# CORS 허용 출처 (콤마로 구분)
# 개발: localhost, Android 에뮬레이터(10.0.2.2)
# 운영: 실제 도메인으로 교체
ALLOWED_ORIGINS=http://localhost:3000,http://10.0.2.2:3000,http://127.0.0.1:3000
